# Copy this file to .env and fill in your values
# NEVER commit .env to source control

PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/taskify?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=<your-long-random-jwt-secret>

# Cookie settings
NODE_ENV=production

# Frontend URL (for CORS — set to your Azure Static Web App URL in production)
CLIENT_URL=https://<your-static-web-app>.azurestaticapps.net
