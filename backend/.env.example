# Copy this file to .env and fill in your values
# NEVER commit .env to source control

PORT=3001

# Azure SQL Database connection
DB_HOST=<your-sql-server>.database.windows.net
DB_NAME=db-taskapp
DB_USER=<your-admin-login>
DB_PASSWORD=<your-strong-password>

# Optional: full connection string (alternative to individual vars)
# DB_CONNECTION_STRING=Server=tcp:<server>.database.windows.net,1433;Database=db-taskapp;User ID=<user>;Password=<password>;Encrypt=true;
